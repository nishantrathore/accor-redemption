        <!-- Scaling annotations -->
        <mxCell id="hpa-box" value="&lt;b&gt;HPA&lt;/b&gt;  (Horizontal Pod Autoscaler)&lt;br&gt;Min: 3  /  Max: 50 replicas&lt;br&gt;Triggers: CPU &gt;60% · Memory &gt;70% · RPS &gt;500&lt;br&gt;Scale-up: immediate  |  Scale-down: 5 min cooldown"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="680" width="370" height="70" as="geometry" />
        </mxCell>
        <mxCell id="keda-box" value="&lt;b&gt;KEDA ScaledObject&lt;/b&gt;  (Event-Driven)&lt;br&gt;Trigger: SQS queue depth (1 pod / 10 msgs)&lt;br&gt;Scales before CPU spike — no lag"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="765" width="370" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pdb-box" value="&lt;b&gt;PodDisruptionBudget&lt;/b&gt;  minAvailable: 70%&lt;br&gt;Prevents full outage during node drains or AZ failure&lt;br&gt;&lt;b&gt;RollingUpdate&lt;/b&gt;  maxUnavailable: 0  /  maxSurge: 2"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="840" width="370" height="60" as="geometry" />
